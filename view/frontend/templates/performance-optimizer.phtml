<?php if ($helper->isDeferThirdPartyEnabled()): ?>
<!-- Performance Optimizer: Defer third-party scripts -->
<script>
(function(){
    'use strict';
    var excludedDomains = <?= /* @noEscape */ $block->getExcludedDomainsJson() ?>;
    var currentHost = window.location.hostname;

    function isThirdParty(src) {
        if (!src) return false;
        try {
            var url = new URL(src, window.location.origin);
            if (url.hostname === currentHost) return false;
            for (var i = 0; i < excludedDomains.length; i++) {
                if (url.hostname.indexOf(excludedDomains[i]) !== -1) return false;
            }
            return true;
        } catch(e) {
            return false;
        }
    }

    function deferThirdPartyScripts() {
        var scripts = document.querySelectorAll('script[src]');
        for (var i = 0; i < scripts.length; i++) {
            var script = scripts[i];
            if (isThirdParty(script.src) && !script.defer && !script.async) {
                script.defer = true;
            }
        }
    }

    // Observe new scripts added to DOM and defer third-party ones
    var observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            mutation.addedNodes.forEach(function(node) {
                if (node.tagName === 'SCRIPT' && node.src && isThirdParty(node.src) && !node.defer && !node.async) {
                    node.defer = true;
                }
            });
        });
    });

    observer.observe(document.documentElement, {childList: true, subtree: true});

    // Also defer existing third-party scripts on DOMContentLoaded
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', deferThirdPartyScripts);
    } else {
        deferThirdPartyScripts();
    }
})();
</script>
<?php endif; ?>

<?php /*
 * set_image_dimensions is handled server-side by
 * Panth\PerformanceOptimizer\Plugin\Layout\InjectImageDimensionsPlugin —
 * width/height attributes are injected before the HTML reaches the browser
 * so the layout reservation is correct on first paint. The previous
 * client-side fallback set dimensions inside the load handler, which fired
 * AFTER the image had already shifted the layout — useless for CLS — so
 * it was removed.
 */ ?>

<?php if ($helper->isIframeLazyLoadEnabled()): ?>
<!-- Performance Optimizer: Lazy load iframes via IntersectionObserver -->
<script>
(function(){
    'use strict';
    function lazyLoadIframes() {
        var iframes = document.querySelectorAll('iframe[src]');
        if (!iframes.length || !('IntersectionObserver' in window)) return;

        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    var iframe = entry.target;
                    if (iframe.dataset.lazySrc) {
                        iframe.src = iframe.dataset.lazySrc;
                        iframe.removeAttribute('data-lazy-src');
                    }
                    observer.unobserve(iframe);
                }
            });
        }, {rootMargin: '200px'});

        iframes.forEach(function(iframe) {
            var rect = iframe.getBoundingClientRect();
            // Only lazy-load iframes below the fold
            if (rect.top > window.innerHeight) {
                iframe.dataset.lazySrc = iframe.src;
                iframe.removeAttribute('src');
                observer.observe(iframe);
            }
        });
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', lazyLoadIframes);
    } else {
        lazyLoadIframes();
    }
})();
</script>
<?php endif; ?>
